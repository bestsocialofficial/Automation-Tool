# Copy this file to .env and fill in your values.
# .env is read automatically by the scripts — never commit it.

# Your SEMrush API key (Account > Subscription info > API units)
SEMRUSH_API_KEY=your_api_key_here

# MongoDB connection. The defaults below are built in — you only need to
# uncomment and change these if your setup differs.
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=seo
# MONGO_COLLECTION=keyword_rankings
